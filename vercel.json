{
  "version": 2,
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/dist",
  "framework": null,
  "functions": {
    "api/telegram.ts": { "maxDuration": 60 },
    "api/health.ts": { "maxDuration": 5 },
    "api/vapi-context.ts": { "maxDuration": 5 },
    "api/dashboard-data.ts": { "maxDuration": 5 },
    "api/evaluate-risk.ts": { "maxDuration": 60 },
    "api/onboard-patient.ts": { "maxDuration": 5 },
    "api/intervention-action.ts": { "maxDuration": 10 },
    "api/regenerate-token.ts": { "maxDuration": 5 },
    "api/interventions-queue.ts": { "maxDuration": 5 },
    "api/patients-roster.ts": { "maxDuration": 5 },
    "api/proactive-checkin.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/proactive-checkin", "schedule": "30 3 * * *" }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|favicon|.*\\.(?:js|css|png|svg|webp|jpg|woff2?)).*)", "destination": "/index.html" }
  ]
}
